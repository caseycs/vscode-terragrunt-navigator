{
  "name": "vscode-terragrunt-navigator",
  "displayName": "Terragrunt Navigator",
  "description": "Ctrl+Click into Terragrunt sources, dependencies, and parent configs — with dynamic interpolation support",
  "version": "0.3.1",
  "publisher": "caseycs",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caseycs/vscode-terragrunt-navigator"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:hcl"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hcl",
        "extensions": [
          ".hcl"
        ],
        "aliases": [
          "HCL",
          "Terragrunt"
        ]
      }
    ],
    "configuration": {
      "title": "Terragrunt Navigator",
      "properties": {
        "terragruntNavigator.renderTimeout": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for terragrunt render --json"
        },
        "terragruntNavigator.backgroundResolution": {
          "type": "boolean",
          "default": true,
          "description": "Pre-resolve dynamic interpolations in the background when a file is opened. Disable to only resolve on click."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "pretest": "npm run compile && tsc -p tsconfig.test.json",
    "test": "node ./out/test/runTests.js",
    "pretest:unit": "tsc -p tsconfig.test.json",
    "test:unit": "mocha './out/test/unit/**/*.test.js'",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.27.5",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2"
  }
}
