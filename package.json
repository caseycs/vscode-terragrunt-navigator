{
  "name": "vscode-terragrunt-navigator",
  "displayName": "Terragrunt Navigator",
  "description": "Ctrl+Click and F12 navigation for Terragrunt source paths",
  "version": "0.1.0",
  "publisher": "terragrunt-navigator",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:hcl"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hcl",
        "extensions": [
          ".hcl"
        ],
        "aliases": [
          "HCL",
          "Terragrunt"
        ]
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "pretest": "npm run compile && tsc -p tsconfig.test.json",
    "test": "node ./out/test/runTests.js",
    "test:unit": "mocha ./out/test/unit/**/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.20.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.4.0"
  }
}
